# Copy to .env and adjust: `make env`.
#
# Real environment variables always override this file -- godotenv does not
# overwrite a variable that is already set. In production the values come from
# your orchestrator (ConfigMaps and Secrets), and there is no .env file at all.
#
# .env is gitignored (and dockerignored, so it never reaches an image layer).
# Never commit real secrets to .env.example.
#
# This file configures THE APP, and it is read when the app runs on your machine
# (`make run`). A containerised app never reads it: under `make up`, the app's
# configuration comes from the `environment:` block in docker-compose.yml, which
# is self-contained. Those are two separate places on purpose -- change this file
# for local runs, change docker-compose.yml for the containerised stack.

# --- App ---
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # text logs + internal errors echoed to the caller.
                             # Startup REFUSES to run with this true in production.
LOG_LEVEL=info               # debug | info | warn | error
# Identifies this replica in logs. In Kubernetes, set it from metadata.name via
# the downward API.
INSTANCE_ID=

# --- HTTP server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=15s
# Honour X-Forwarded-For / X-Real-IP when recording the client IP on sessions and
# audit entries. Turn this on ONLY when the app sits behind a proxy you control
# that overwrites those headers. If the app is directly reachable, a caller can
# forge them, and you would be writing attacker-chosen IPs into your audit log.
SERVER_TRUST_PROXY_HEADERS=false

# --- Postgres (the only source of truth: no cache tier, no Redis) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# ONE user, owning ONE database -- the app's own. The app never connects as the
# cluster superuser and never touches another database.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
POSTGRES_SSLMODE=disable     # Startup REFUSES 'disable' when APP_ENV=production
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m

# --- Auth ---
AUTH_SESSION_TTL=720h        # 30 days: how long a session token stays valid
AUTH_INVITATION_TTL=168h     # 7 days: how long an invitation link stays valid
# Deliberately SHORT. Unlike an invitation, a reset link is a credential an
# attacker may have triggered against somebody else's account; every hour it stays
# alive is an hour it can be intercepted. A zero value is refused at startup -- it
# would mint links that are expired the instant they are created.
AUTH_PASSWORD_RESET_TTL=1h
AUTH_EMAIL_VERIFY_TTL=24h

# Gate ORGANIZATION CREATION on a confirmed email address -- not login. Locking somebody
# out of their own account because a verification mail went to spam is a support
# nightmare for little gain; stopping an unverified address from standing up
# organizations is the control that matters, and it doubles as abuse prevention.
#
# Accepting an invitation ALSO verifies the address, since the token was emailed
# there and nowhere else -- holding it IS proof of control.
AUTH_REQUIRE_VERIFIED_EMAIL=true

# Cap live organizations per account. Without it, one account stands up unlimited
# organizations: free storage for an abuser, a bill for you. 0 = no limit.
AUTH_MAX_ORGANIZATIONS_PER_USER=10
AUTH_MIN_PASSWORD_LENGTH=12  # length is the only rule; see OWASP on composition rules

# argon2id cost. The defaults are OWASP's recommendation (19 MiB, t=2, p=1).
# Raise them if your hardware allows -- the parameters are stored inside each
# hash, so existing passwords keep verifying and are silently upgraded on the
# owner's next successful login.
#
# Do NOT lower these to speed up tests: tests set their own cost.
AUTH_ARGON_MEMORY_KIB=19456
AUTH_ARGON_ITERATIONS=2
AUTH_ARGON_PARALLELISM=1

# --- Mail ---
# "log" prints the whole email -- INCLUDING THE INVITATION AND PASSWORD-RESET
# LINKS -- to the application log. That is what makes this template runnable with
# no setup: invite somebody, then read the link out of `docker compose logs app`.
#
# Those links are working credentials, so startup REFUSES this backend when
# APP_ENV=production. Use smtp there.
MAIL_BACKEND=log             # log | smtp
MAIL_FROM=no-reply@example.com

# The public origin of your FRONT END -- whatever receives the links in these
# emails and hands the token back to this API. Not the API's own address, unless
# they are the same thing. Startup refuses a localhost value in production, since
# the links would be unusable.
APP_BASE_URL=http://localhost:8080

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Rate limiting ---
# IN-MEMORY, and therefore PER-REPLICA: three replicas means three times this
# allowance, and a restart forgets everything. It is a speed bump, not a wall --
# put the real limiter at your proxy or WAF, where it sees every replica.
#
# Guards /auth/login, /auth/register, /auth/password/reset, /invitations/accept.
# Login and reset are keyed by IP *and* by email: IP alone lets one attacker spray
# a thousand accounts at one attempt each; email alone lets a botnet hammer one
# account from a thousand addresses.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=10
RATE_LIMIT_WINDOW=1m

# --- Audit ---
# How long audit entries are kept. 0 (the default) means KEEP FOREVER.
#
# Deliberately not defaulted to something convenient like 90d: quietly destroying
# your compliance evidence because a config value had a tidy default is not a
# decision this template will make for you. Set it once you know your obligations
# -- most regimes want years. Note that "forever" is a real answer too, right up
# until a right-to-erasure request arrives.
#
# The retention sweep is the ONLY thing allowed to delete an audit entry: a
# database trigger refuses every other DELETE, and every UPDATE, for every role
# including the superuser. An audit trail a compromised app can rewrite is not an
# audit trail.
AUDIT_RETENTION=0

# --- Organization lifecycle ---
# How long a SOFT-DELETED organization is kept before `server purge` destroys it for
# real, cascading away every row it owns. 0 (the default) = KEEP FOREVER.
#
# This is your right-to-erasure mechanism. It is off by default for the same reason
# AUDIT_RETENTION is: shredding a customer's data because a config value had a tidy
# default is not a decision this template makes. 720h (30d) is a common choice and
# leaves support time to undo an accident.
ORGANIZATION_RETENTION=0

# --- CORS ---
# An explicit allowlist of browser origins, comma-separated. EMPTY = CORS OFF,
# which is correct for an API with no browser client: no origin is echoed, so no
# other site can call this API at all.
#
# A "*" wildcard is REFUSED at startup in production. This API authenticates with
# bearer tokens, and a wildcard origin plus credentials is the one combination the
# CORS spec forbids -- every site on the internet could make authenticated calls
# with your users' tokens.
CORS_ALLOWED_ORIGINS=

# --- Tests ---
# Integration tests run against a real Postgres. Without this set they SKIP, so
# `go test ./...` still works on a machine with no database.
# `make test-integration` starts a throwaway Postgres and sets this for you.
# TEST_POSTGRES_DSN=postgres://app:app@localhost:5433/app?sslmode=disable
